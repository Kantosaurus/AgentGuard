# AI Attack Validation Test Suite — Environment Configuration
# Copy to .env and fill in your API keys

# At least one API key required
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Target model to test against (default: gpt-4o)
# OpenAI: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# Anthropic: claude-sonnet-4-20250514, claude-haiku-4-20250414
# Gemini: gemini-2.0-flash, gemini-2.0-pro
TARGET_MODEL=gpt-4o

# Provider: openai | anthropic | gemini (auto-detected from TARGET_MODEL if omitted)
# PROVIDER=openai

# Optional: max tokens per response
MAX_TOKENS=1024

# Optional: temperature (default 0.0 for reproducibility)
TEMPERATURE=0
