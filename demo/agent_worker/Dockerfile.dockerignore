**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
.venv
venv
env

# Worker never loads a model; exclude all training artefacts.
data/processed
data/dataset

results
logs
sweep/runs
sweep/artifacts
notebooks
docs

.DS_Store
Thumbs.db
